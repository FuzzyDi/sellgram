{
  "name": "sellgram",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "dev": "corepack pnpm -r --parallel --filter @sellgram/api --filter @sellgram/admin --filter @sellgram/miniapp run dev",
    "build": "corepack pnpm -r --if-present run build",
    "lint": "corepack pnpm -r --if-present run lint",
    "test": "corepack pnpm --filter @sellgram/api test -- --run",
    "dev:turbo": "turbo run dev",
    "build:turbo": "turbo run build",
    "lint:turbo": "turbo run lint",
    "test:turbo": "turbo run test",
    "db:migrate": "corepack pnpm --filter @sellgram/prisma run migrate",
    "db:seed": "corepack pnpm --filter @sellgram/prisma run seed",
    "db:generate": "corepack pnpm --filter @sellgram/prisma run generate",
    "db:studio": "corepack pnpm --filter @sellgram/prisma run studio",
    "bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap.ps1",
    "doctor:prod": "bash deploy/production/post-deploy-checklist.sh"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "overrides": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  }
}
