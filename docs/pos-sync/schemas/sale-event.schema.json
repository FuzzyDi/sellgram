{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sale-event.schema.json",
  "title": "POS Sync API — POST /api/pos/v1/sale-events",
  "definitions": {
    "SaleEvent": {
      "type": "object",
      "required": [
        "deviceId", "storeId", "localSaleId", "localShiftId", "eventType",
        "status", "receiptNumber", "idempotencyKey", "occurredAt",
        "items", "payments", "totals", "fiscal", "print"
      ],
      "properties": {
        "deviceId": { "type": "string" },
        "storeId": { "type": "string" },
        "localSaleId": { "type": "string" },
        "localShiftId": { "type": "string" },
        "eventType": {
          "type": "string",
          "enum": [
            "SALE_CREATED", "SALE_PAID", "SALE_FISCALIZED", "SALE_COMPLETED",
            "SALE_CANCELLED", "SALE_REFUNDED", "SALE_FISCAL_UNKNOWN"
          ]
        },
        "status": {
          "type": "string",
          "enum": ["FISCALIZED", "FISCAL_UNKNOWN", "COMPLETED", "CANCELLED", "REFUNDED"]
        },
        "receiptNumber": { "type": "integer" },
        "idempotencyKey": { "type": "string", "pattern": "^[^:]+:sale:[^:]+:[A-Z_]+$" },
        "occurredAt": { "type": "string", "format": "date-time" },
        "items": { "type": "array", "items": { "type": "object" } },
        "payments": { "type": "array", "items": { "type": "object" } },
        "totals": { "type": "object" },
        "fiscal": { "type": "object" },
        "print": { "type": "object" }
      },
      "additionalProperties": false
    },
    "SaleEventWarning": {
      "type": "object",
      "required": ["index", "code", "message"],
      "properties": {
        "index": { "type": "integer", "minimum": 0 },
        "code": { "type": "string", "enum": ["UNKNOWN_PRODUCT", "MISSING_PRODUCT_REFERENCE", "INVALID_QUANTITY"] },
        "message": { "type": "string" },
        "productId": { "type": "string" }
      },
      "additionalProperties": false,
      "description": "Per-line-item ingest warning (POS_SYNC_API.md §11/§18) — the event is accepted regardless; a warned item just produced no stock ledger entry."
    },
    "SaleEventResponse": {
      "type": "object",
      "required": ["success", "data", "requestId"],
      "properties": {
        "success": { "const": true },
        "data": {
          "type": "object",
          "required": ["eventId", "warnings"],
          "properties": {
            "eventId": { "type": "string" },
            "warnings": { "type": "array", "items": { "$ref": "#/definitions/SaleEventWarning" } }
          },
          "additionalProperties": false
        },
        "requestId": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
