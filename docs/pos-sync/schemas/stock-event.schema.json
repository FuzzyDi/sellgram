{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "stock-event.schema.json",
  "title": "POS Sync API — POST /api/pos/v1/stock-events",
  "definitions": {
    "StockEvent": {
      "type": "object",
      "required": ["deviceId", "storeId", "productId", "delta", "reason", "idempotencyKey", "occurredAt"],
      "properties": {
        "deviceId": { "type": "string" },
        "storeId": { "type": "string" },
        "productId": { "type": "string" },
        "variantId": { "type": ["string", "null"] },
        "delta": { "type": "integer", "description": "Signed quantity change." },
        "reason": {
          "type": "string",
          "enum": ["POS_ADJUSTMENT", "RESTOCK", "OTHER"],
          "description": "POS_SALE is deliberately excluded — it is only ever derived from sale events, never accepted directly here. Matches StockLedgerReason in packages/prisma/schema.prisma minus POS_SALE."
        },
        "idempotencyKey": { "type": "string", "pattern": "^[^:]+:stock:[^:]+:[A-Z_]+$" },
        "occurredAt": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "StockEventWarning": {
      "type": "object",
      "required": ["index", "code", "message"],
      "properties": {
        "index": { "type": "integer", "const": 0, "description": "Always 0 — a stock event has exactly one item; kept for shape-consistency with sale-event warnings." },
        "code": { "type": "string", "enum": ["UNKNOWN_PRODUCT", "UNKNOWN_VARIANT"] },
        "message": { "type": "string" },
        "productId": { "type": "string" }
      },
      "additionalProperties": false
    },
    "StockEventResponse": {
      "type": "object",
      "required": ["success", "data", "requestId"],
      "properties": {
        "success": { "const": true },
        "data": {
          "type": "object",
          "required": ["eventId", "warnings"],
          "properties": {
            "eventId": { "type": "string" },
            "warnings": { "type": "array", "items": { "$ref": "#/definitions/StockEventWarning" } }
          },
          "additionalProperties": false
        },
        "requestId": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
