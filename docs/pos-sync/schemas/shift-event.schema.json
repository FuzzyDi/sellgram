{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "shift-event.schema.json",
  "title": "POS Sync API — POST /api/pos/v1/shift-events (real SBG Lite POS Android contract, fiscal/shift/commands v1, 2026-07-04)",
  "definitions": {
    "ShiftEvent": {
      "type": "object",
      "required": [
        "eventId", "eventType", "aggregateType", "aggregateId", "idempotencyKey",
        "schemaVersion", "shiftNumber", "shiftState", "zReportStatus",
        "rawDaemonResponse", "rawShiftPayload"
      ],
      "properties": {
        "eventId": { "type": "string" },
        "eventType": { "type": "string", "enum": ["SHIFT_OPENED", "SHIFT_CLOSED"] },
        "aggregateType": { "type": "string", "description": "Observed value: \"SHIFT\"." },
        "aggregateId": { "type": "string" },
        "idempotencyKey": { "type": "string" },
        "schemaVersion": { "type": "integer" },
        "shiftNumber": { "type": "integer" },
        "shiftState": {
          "type": "string",
          "description": "Free-form, not a closed enum — observed: OPEN, CLOSED_WITH_Z."
        },
        "openedAtMs": { "type": ["integer", "null"], "description": "Epoch milliseconds." },
        "closedAtMs": { "type": ["integer", "null"], "description": "Epoch milliseconds." },
        "zReportStatus": {
          "type": "string",
          "description": "Free-form, not a closed enum — observed: NOT_STARTED, CLOSED."
        },
        "rawDaemonResponse": { "type": "object", "description": "Stored as-is, JSONB." },
        "rawShiftPayload": { "type": "object", "description": "Stored as-is, JSONB." }
      },
      "additionalProperties": true
    },
    "ShiftEventAckResponse": {
      "type": "object",
      "required": ["success", "requestId"],
      "properties": {
        "success": { "const": true },
        "requestId": { "type": "string" }
      },
      "additionalProperties": false,
      "description": "Same flat ack shape as fiscal-event.schema.json's FiscalEventAckResponse — see POS_SYNC_API.md §13."
    }
  }
}
