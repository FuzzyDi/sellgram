generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum UserRole {
  OWNER
  MANAGER
  OPERATOR
  MARKETER
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  MANUAL_TRANSFER
  TELEGRAM
  CLICK
  PAYME
  UZUM
  STRIPE
  CUSTOM
}

enum PaymentProvider {
  CASH
  MANUAL_TRANSFER
  TELEGRAM
  CLICK
  PAYME
  UZUM
  STRIPE
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum DeliveryType {
  PICKUP
  LOCAL
  NATIONAL
}

enum LoyaltyTxnType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
}

enum POStatus {
  DRAFT
  ORDERED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum ScheduledFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ============================================================
// TENANT & AUTH
// ============================================================

model Tenant {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users             User[]
  stores            Store[]
  products          Product[]
  categories        Category[]
  customers         Customer[]
  orders            Order[]
  deliveryZones     DeliveryZone[]
  loyaltyConfig     LoyaltyConfig?
  purchaseOrders    PurchaseOrder[]
  suppliers         Supplier[]
  promoCodes        PromoCode[]
  invoices          Invoice[]
  paymentMethods    StorePaymentMethod[]
  broadcasts        BroadcastCampaign[]
  scheduledReports  ScheduledReport[]
  auditLogs         TenantAuditLog[]
  banners           Banner[]
  apiKeys           ApiKey[]
  webhooks          Webhook[]

  @@map("tenants")
}

model User {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email           String   @unique
  passwordHash    String
  name            String
  role            UserRole @default(OWNER)
  permissions     Json?
  adminTelegramId BigInt?  // For receiving order notifications in Telegram
  telegramLinkCode String?
  telegramLinkCodeExpiresAt DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  broadcastsCreated BroadcastCampaign[] @relation("BroadcastCreatedBy")

  @@index([tenantId])
  @@map("users")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  prefix     String
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  events    Json     // string[] e.g. ["order.created","order.status_changed"]
  secret    String   // whsec_xxx for HMAC-SHA256 signing
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("webhooks")
}

// ============================================================
// STORE (Telegram Bot)
// ============================================================

model Store {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  botToken       String   // AES-256-GCM encrypted
  botUsername     String?
  webhookSecret  String   @default(cuid())
  welcomeMessage String?  @default("Welcome! Tap the button below to open the store.")
  miniAppUrl     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders         Order[]
  deliveryZones  DeliveryZone[]
  paymentMethods StorePaymentMethod[]
  broadcasts     BroadcastCampaign[]

  @@index([tenantId])
  @@map("stores")
}

// ============================================================
// CATALOG
// ============================================================

model Category {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  sortOrder Int        @default(0)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

model Product {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  description   String?
  price         Decimal         @db.Decimal(12, 2)
  costPrice     Decimal?        @db.Decimal(12, 2)
  currency      String          @default("UZS")
  sku           String?
  stockQty      Int             @default(0)
  lowStockAlert Int             @default(5)
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  images         ProductImage[]
  variants       ProductVariant[]
  orderItems     OrderItem[]
  poItems        PurchaseOrderItem[]
  wishlistItems  WishlistItem[]
  stockMovements StockMovement[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, isActive])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)

  @@map("product_images")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sku       String?
  price     Decimal? @db.Decimal(12, 2)
  stockQty  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  orderItems OrderItem[]

  @@map("product_variants")
}

model StockMovement {
  id         String   @id @default(cuid())
  tenantId   String
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  delta      Int
  qtyBefore  Int
  qtyAfter   Int
  note       String?
  userId     String?
  createdAt  DateTime @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("stock_movements")
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  telegramId    BigInt
  telegramUser  String?
  firstName     String?
  lastName      String?
  languageCode  String?
  phone         String?
  loyaltyPoints Int      @default(0)
  totalSpent    Decimal  @default(0) @db.Decimal(12, 2)
  ordersCount   Int      @default(0)
  tags          String[] @default([])
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders      Order[]
  loyaltyTxns LoyaltyTransaction[]
  cartItems   CartItem[]
  broadcastRecipients BroadcastRecipient[]
  wishlistItems WishlistItem[]
  addresses   CustomerAddress[]

  @@unique([tenantId, telegramId])
  @@index([tenantId])
  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenantId   String
  label      String   @default("home")
  address    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@map("customer_addresses")
}

// ============================================================
// CART (server-side)
// ============================================================

model CartItem {
  id         String          @id @default(cuid())
  customerId String
  customer   Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  storeId    String
  productId  String
  variantId  String?
  qty        Int             @default(1)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([customerId, storeId, productId, variantId])
  @@index([customerId, storeId])
  @@map("cart_items")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String        @id @default(cuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id])
  orderNumber     Int
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  status          OrderStatus   @default(NEW)
  paymentMethod   PaymentMethod @default(CASH_ON_DELIVERY)
  paymentMethodId String?
  paymentMethodRef StorePaymentMethod? @relation("OrderToStorePaymentMethod", fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentMethodCode String?
  paymentMethodTitle String?
  paymentMeta    Json?
  paymentStatus   PaymentStatus @default(PENDING)

  // Delivery
  deliveryType    DeliveryType
  deliveryZoneId  String?
  deliveryZone    DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  deliveryAddress String?
  deliveryPrice   Decimal?      @db.Decimal(12, 2)
  trackingNumber  String?

  // Totals
  subtotal          Decimal @db.Decimal(12, 2)
  discount          Decimal @default(0) @db.Decimal(12, 2)
  loyaltyDiscount   Decimal @default(0) @db.Decimal(12, 2)
  loyaltyPointsUsed Int     @default(0)
  promoDiscount     Decimal @default(0) @db.Decimal(12, 2)
  promoCodeId       String?
  promoCode         PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  total             Decimal @db.Decimal(12, 2)

  note         String?
  cancelReason String?
  refundAmount Decimal? @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        OrderItem[]
  statusHistory OrderStatusLog[]
  review       OrderReview?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([paymentMethodId])
  @@index([tenantId, storeId])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@index([deliveryZoneId])
  @@map("orders")
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  name      String
  variantName String?
  price     Decimal         @db.Decimal(12, 2)
  qty       Int
  total     Decimal         @db.Decimal(12, 2)

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

model OrderStatusLog {
  id        String       @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus  OrderStatus
  changedBy String?
  note      String?
  createdAt DateTime     @default(now())

  @@index([orderId])
  @@map("order_status_logs")
}

model OrderReview {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  tenantId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([customerId])
  @@map("order_reviews")
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId   String
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("wishlist_items")
}

model PromoCode {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String
  type           String    @default("PERCENT") // PERCENT | FIXED
  value          Decimal   @db.Decimal(12, 2)
  minOrderAmount Decimal?  @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  orders         Order[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("promo_codes")
}

model PaymentWebhookEvent {
  id          String   @id @default(cuid())
  orderId     String
  eventId     String
  provider    String
  processedAt DateTime @default(now())

  @@unique([orderId, eventId])
  @@index([orderId])
  @@map("payment_webhook_events")
}

model Banner {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String?
  imageUrl  String
  linkUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("banners")
}

// ============================================================
// DELIVERY
// ============================================================

model DeliveryZone {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String?
  store     Store?  @relation(fields: [storeId], references: [id])
  name      String
  price     Decimal @db.Decimal(12, 2)
  freeFrom  Decimal? @db.Decimal(12, 2)
  etaMin    Int?    // minutes
  etaMax    Int?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  orders Order[]

  @@index([tenantId])
  @@map("delivery_zones")
}

// ============================================================
// LOYALTY
// ============================================================

model LoyaltyConfig {
  id                String  @id @default(cuid())
  tenantId          String  @unique
  tenant            Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isEnabled         Boolean @default(false)
  pointsPerUnit     Int     @default(1)
  unitAmount        Int     @default(1000)    // 1 point per 1000 UZS
  pointValue        Int     @default(100)     // 1 point = 100 UZS
  maxDiscountPct    Int     @default(30)
  minPointsToRedeem Int     @default(100)

  @@map("loyalty_configs")
}

model LoyaltyTransaction {
  id           String         @id @default(cuid())
  customerId   String
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenantId     String
  type         LoyaltyTxnType
  points       Int
  balanceAfter Int
  orderId      String?
  description  String?
  createdAt    DateTime       @default(now())

  @@index([customerId])
  @@index([tenantId])
  @@map("loyalty_transactions")
}

// ============================================================
// PROCUREMENT
// ============================================================

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  note        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  poNumber     Int
  supplierName String
  status       POStatus @default(DRAFT)
  currency     String   @default("USD")
  fxRate       Decimal? @db.Decimal(12, 6)
  shippingCost Decimal  @default(0) @db.Decimal(12, 2)
  customsCost  Decimal  @default(0) @db.Decimal(12, 2)
  totalCost    Decimal  @default(0) @db.Decimal(12, 2)
  totalLanded  Decimal  @default(0) @db.Decimal(12, 2)
  note         String?
  orderedAt    DateTime?
  receivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  qty             Int
  unitCost        Decimal       @db.Decimal(12, 2)
  totalCost       Decimal       @db.Decimal(12, 2)
  qtyReceived     Int           @default(0)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// ============================================================
// BILLING (manual invoices)
// ============================================================

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum BroadcastStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
}

enum BroadcastTargetType {
  ALL
  SELECTED
}

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan        Plan
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("UZS")
  status      InvoiceStatus @default(PENDING)
  paymentRef  String?       // Transaction ID from bank transfer
  paymentNote String?       // Owner's note about payment
  confirmedBy String?       // Admin user ID who confirmed
  confirmedAt DateTime?
  expiresAt   DateTime      // Invoice expires after 48h
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

model StorePaymentMethod {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider     PaymentProvider @default(CUSTOM)
  code         String
  title        String
  description  String?
  instructions String?
  isActive     Boolean         @default(true)
  isDefault    Boolean         @default(false)
  sortOrder    Int             @default(0)
  meta         Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  orders Order[] @relation("OrderToStorePaymentMethod")

  @@unique([storeId, code])
  @@index([tenantId, storeId, isActive])
  @@map("store_payment_methods")
}

model BroadcastCampaign {
  id              String              @id @default(cuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId         String
  store           Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User                @relation("BroadcastCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  title           String?
  message         String
  targetType      BroadcastTargetType
  status          BroadcastStatus     @default(DRAFT)
  totalRecipients Int                 @default(0)
  sentCount       Int                 @default(0)
  failedCount     Int                 @default(0)
  createdAt       DateTime            @default(now())
  sentAt          DateTime?

  recipients BroadcastRecipient[]

  @@index([tenantId, storeId, createdAt])
  @@map("broadcast_campaigns")
}

model BroadcastRecipient {
  id         String            @id @default(cuid())
  campaignId String
  campaign   BroadcastCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  telegramId BigInt
  success    Boolean           @default(false)
  error      String?
  sentAt     DateTime?

  @@unique([campaignId, customerId])
  @@index([campaignId, success])
  @@map("broadcast_recipients")
}

model SystemAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("system_admins")
}







model TenantAuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId   String?
  action    String
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("tenant_audit_logs")
}

enum SystemAuditAction {
  TENANT_PLAN_UPDATED
  INVOICE_CONFIRMED
  INVOICE_REJECTED
}

model SystemAuditLog {
  id        String            @id @default(cuid())
  action    SystemAuditAction
  actorId   String?
  actorEmail String?
  targetType String
  targetId  String
  details   Json?
  createdAt DateTime          @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("system_audit_logs")
}

model SystemSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model ScheduledReport {
  id         String             @id @default(cuid())
  tenantId   String
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportType String             // top-products | revenue | categories | customers
  periodDays Int
  frequency  ScheduledFrequency
  isActive   Boolean            @default(true)
  lastSentAt DateTime?
  nextRunAt  DateTime
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([tenantId])
  @@index([nextRunAt, isActive])
  @@map("scheduled_reports")
}
