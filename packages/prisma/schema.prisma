// ============================================================
// POS SYNC (SBGCloud) — see docs/SBGCLOUD_ARCHITECTURE.md
// First wave only: device identity, activation, catalog snapshot, stock
// ledger. Sale/fiscal/shift ingestion intentionally NOT modeled yet —
// pending a confirmed fiscal integration partner for Uzbekistan.
// ============================================================

enum PosDeviceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

enum DeviceActivationStatus {
  PENDING
  CONFIRMED
  EXPIRED
}

enum StockLedgerReason {
  POS_SALE
  POS_ADJUSTMENT
  RESTOCK
  OTHER
}

model PosDevice {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  deviceType   String
  status       PosDeviceStatus @default(PENDING)
  // Device credential, same hash-only pattern as ApiKey.keyHash/prefix —
  // the raw key is shown once at activation time and never stored.
  apiKeyHash   String?         @unique
  apiKeyPrefix String?
  // Minted alongside apiKeyHash at activation (docs/POS_SYNC_API.md §7),
  // but there is no refresh-verification endpoint yet — accessToken
  // (apiKeyHash) is treated as long-lived in practice until one exists.
  refreshTokenHash   String?   @unique
  refreshTokenPrefix String?
  // Device-reported at activation, kept separate from the admin-set
  // name/deviceType above (which stay authoritative for fleet display) —
  // deviceFingerprint is used only for the reactivation-anomaly check.
  deviceFingerprint  String?
  reportedDeviceName String?
  reportedDeviceType String?
  appVersion         String?
  // PUBLIC device identifier (not a secret — safe to log), sent by the
  // device at /activate the same way as deviceFingerprint — confirmed
  // production flow with the SBG Lite POS Android team (their client
  // derives it from local config). Checked as a PAIR with Authorization:
  // Bearer on every other authenticated endpoint (docs/POS_SYNC_API.md
  // §4/§22): Bearer remains the sole real auth factor; a request whose
  // token was issued for a different deviceCode is rejected, not just a
  // present-but-unrelated header. Unique per tenant (two devices of one
  // tenant can't share a code; different tenants may reuse the same
  // dev-style value, e.g. "POS-1") — nullable only for pre-existing rows
  // that activated before this column existed.
  deviceCode   String?
  lastSeenAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  activations DeviceActivation[]
  syncCursor  SyncCursor?
  saleEvents  SaleEvent[]
  stockEvents StockEvent[]
  fiscalEvents FiscalEvent[]
  shiftEvents  ShiftEvent[]
  cloudCommands CloudCommand[]

  @@unique([tenantId, deviceCode])
  @@index([tenantId, storeId])
  @@map("pos_devices")
}

model DeviceActivation {
  id             String                 @id @default(cuid())
  deviceId       String
  device         PosDevice              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  activationCode String                 @unique
  status         DeviceActivationStatus @default(PENDING)
  expiresAt      DateTime
  confirmedAt    DateTime?
  createdAt      DateTime               @default(now())

  @@index([deviceId])
  @@map("device_activations")
}

model CatalogSnapshot {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  version   Int
  payload   Json
  createdAt DateTime @default(now())

  @@index([tenantId, storeId, version])
  @@map("catalog_snapshots")
}

enum SaleEventType {
  SALE_CREATED
  SALE_PAID
  SALE_FISCALIZED
  SALE_COMPLETED
  SALE_CANCELLED
  SALE_REFUNDED
  SALE_FISCAL_UNKNOWN
}

enum SaleEventStatus {
  FISCALIZED
  FISCAL_UNKNOWN
  COMPLETED
  CANCELLED
  REFUNDED
}

// Append-only cloud-side mirror of sales that already completed locally
// (docs/POS_SYNC_API.md §5/§11). Never mutated — corrections arrive as new
// events (SALE_CANCELLED, SALE_REFUNDED, FISCAL_RECOVERED), never edits.
// payloadHash + the unique idempotencyKey implement §5: an identical replay
// returns the stored result; a different payload under the same key is a
// client bug rejected with 409 IDEMPOTENCY_KEY_REUSED.
model SaleEvent {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId       String
  device         PosDevice       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  localSaleId    String
  localShiftId   String
  eventType      SaleEventType
  status         SaleEventStatus
  receiptNumber  Int
  idempotencyKey String          @unique
  payloadHash    String
  occurredAt     DateTime
  payload        Json
  // Per-item ingest warnings (UNKNOWN_PRODUCT etc, docs/POS_SYNC_API.md
  // §11/§18) — stored, not recomputed, so a §5 replay returns the exact
  // same body the first attempt got.
  warnings       Json
  createdAt      DateTime        @default(now())

  // Additive fields for the POS Policy Engine (docs/POS_POLICY_ENGINE.md
  // §8) — nullable at the storage level (existing rows predate these
  // columns, no backfill), even though the API layer requires
  // policiesVersion/triggeredRuleIds on every new request.
  policiesVersion  Int?
  // Flat list of matched rule ids — same plain-string-array shape as
  // Customer.tags, not a Json blob like tenantPolicyRules (which stores
  // full rule objects, not ids).
  triggeredRuleIds String[] @default([])
  // Present only if a REQUIRE_MANAGER rule was overridden. Shape not
  // pinned down by §8/§12.2 yet (not needed until that severity is
  // actually implemented) — stored as an opaque blob, not a typed column.
  managerOverride  Json?

  @@index([tenantId, storeId, localSaleId])
  @@index([tenantId, occurredAt])
  @@map("sale_events")
}

// Non-sale stock movement reported by a till (docs/POS_SYNC_API.md §14) —
// cashier stock-count correction or manual restock. Append-only, same §5
// idempotency semantics as SaleEvent. productId deliberately has NO foreign
// key: the event must survive referencing a product unknown to Cloud
// (§18 accept-don't-reject) — the derived StockLedgerEntry row (which does
// FK to Product) is simply skipped in that case, with a stored warning.
model StockEvent {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId       String
  device         PosDevice         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  productId      String
  variantId      String?
  delta          Int
  // Shares StockLedgerReason with the ledger, but the API layer only
  // accepts POS_ADJUSTMENT/RESTOCK/OTHER — POS_SALE rows are exclusively
  // derived from sale events (§14).
  reason         StockLedgerReason
  idempotencyKey String            @unique
  payloadHash    String
  occurredAt     DateTime
  note           String?
  warnings       Json
  createdAt      DateTime          @default(now())

  @@index([tenantId, storeId, productId])
  @@map("stock_events")
}

enum FiscalEventType {
  FISCAL_STARTED
  FISCAL_SUCCESS
  FISCAL_FAILED
  FISCAL_UNKNOWN
}

enum FiscalReceiptType {
  SALE
  REFUND
}

// Cloud-side mirror of a fiscal-module receipt lifecycle, per the real SBG
// Lite POS Android contract (fiscal/shift/commands v1, 2026-07-04) — not
// the earlier speculative shape in docs/pos-sync/schemas/fiscal-event
// .schema.json §12 (superseded, see doc update). Append-only: a device
// reports FISCAL_STARTED, then later FISCAL_SUCCESS/FAILED/UNKNOWN for the
// same aggregateId as new rows, never edits of the prior one — an
// already-stored FISCAL_UNKNOWN/FAILED is never rewritten into a success.
// Same tenantId/storeId denormalization pattern as SaleEvent/StockEvent
// even though both are derivable via device — kept for query/index parity.
// Status-shaped fields (fiscalStatus/printStatus/ofdStatus) are plain
// strings, not Prisma enums — the source contract does not give an
// exhaustive value list and firmware may add values without a migration.
// receiptNumber/originalReceiptNumber/fiscalReceiptNumber are String
// because the real contract sends either an Int or a String for these
// depending on receipt type (see doc §2.2 vs §2.3) — normalized to string.
model FiscalEvent {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId       String
  device         PosDevice         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  eventId        String
  eventType      FiscalEventType
  aggregateType  String
  aggregateId    String
  idempotencyKey String
  schemaVersion  Int
  shiftNumber    Int
  localReceiptId String
  daemonJournalId String?
  receiptNumber  String?
  receiptType    FiscalReceiptType?
  originalLocalReceiptId String?
  originalReceiptNumber  String?
  totalAmount    Int
  currency       String
  payments       Json
  items          Json
  createdAtMs    DateTime
  fiscalizedAtMs DateTime?
  fiscalStatus   String
  printStatus    String
  fiscalReceiptNumber String?
  fiscalSign     String?
  fiscalQr       String?
  ofdStatus      String?
  errorCode      String?
  errorMessage   String?
  rawDaemonResponse Json
  rawFiscalPayload  Json?
  payloadHash    String
  createdAt      DateTime          @default(now())

  // Additive fields for the POS Policy Engine (docs/POS_POLICY_ENGINE.md
  // §8) — same nullable-at-storage/required-at-API split as SaleEvent
  // above.
  policiesVersion  Int?
  triggeredRuleIds String[] @default([])
  managerOverride  Json?

  @@unique([deviceId, eventId])
  @@index([deviceId, localReceiptId])
  @@index([deviceId, receiptNumber])
  @@index([deviceId, receiptType, idempotencyKey])
  @@index([deviceId, shiftNumber])
  @@map("fiscal_events")
}

enum ShiftEventType {
  SHIFT_OPENED
  SHIFT_CLOSED
}

// Cloud-side mirror of a till shift lifecycle, per the real SBG Lite POS
// Android contract §3. Same append-only / eventId-keyed idempotency model
// as FiscalEvent — see that model's comment.
model ShiftEvent {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId       String
  device         PosDevice      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  eventId        String
  eventType      ShiftEventType
  aggregateType  String
  aggregateId    String
  idempotencyKey String
  schemaVersion  Int
  shiftNumber    Int
  shiftState     String
  openedAtMs     DateTime?
  closedAtMs     DateTime?
  zReportStatus  String
  rawDaemonResponse Json
  rawShiftPayload   Json
  payloadHash    String
  createdAt      DateTime       @default(now())

  @@unique([deviceId, eventId])
  @@index([deviceId, shiftNumber])
  @@map("shift_events")
}

enum CloudCommandType {
  PING
  REFRESH_CATALOG
  REFRESH_SETTINGS
  SHOW_MESSAGE
}

enum CloudCommandStatus {
  PENDING
  ACKED
}

enum CloudCommandAckStatus {
  DONE
  FAILED
  IGNORED
  RETRY_LATER
}

// A narrow, non-blocking channel for Cloud to signal a device (§6 of the
// real contract) — never a channel for anything that could create a
// receipt/payment/refund/fiscal operation or gate a local sale (§9 of
// docs/SBGCLOUD_ARCHITECTURE.md). Nothing in this codebase creates
// CloudCommand rows yet (no admin UI wired up) — GET /commands will
// legitimately return an empty list until that exists; this is the
// polling/ack surface only.
model CloudCommand {
  id         String                  @id @default(cuid())
  tenantId   String
  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deviceId   String
  device     PosDevice               @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  type       CloudCommandType
  payload    Json
  status     CloudCommandStatus      @default(PENDING)
  createdAt  DateTime                @default(now())
  ackedAt    DateTime?
  ackStatus  CloudCommandAckStatus?
  ackMessage String?

  @@index([deviceId, status])
  @@map("cloud_commands")
}

// Store-scoped POS operational settings (docs/POS_SYNC_API.md §10).
// payload is the eight-key settings body (taxProfile, paymentMethods, ...)
// with intentionally unconstrained internals — the nested shapes depend on
// the eventual Uzbekistan fiscal integration partner and are not modeled
// as columns on purpose. version bumps on every store-admin write.
model PosSettings {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String   @unique
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  version   Int      @default(1)
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Additive fields for the POS Policy Engine (docs/POS_POLICY_ENGINE.md
  // §3.2/§13 step 1). `version`/`payload` above are deliberately NOT
  // renamed — the doc's response shape calls them settingsVersion/
  // settings at the API level only; the storage/columns are untouched.
  policiesVersion       Int  @default(1)
  // Tenant-authored rule objects ONLY (docs/POS_POLICY_ENGINE.md §4
  // shape) — platform rules are never stored here, always sourced from
  // PlatformPolicy at request time (§6/§7 of that doc — not implemented
  // yet, that's step 3).
  tenantPolicyRules     Json @default("[]")
  printTemplatesVersion Int  @default(1)
  // Print business-policy fields (docs/POS_POLICY_ENGINE.md §2/§10) —
  // despite the name, this is not receipt markup templates, it's
  // autoPrintReceipt/printCopies/etc.
  printTemplates        Json @default("{}")

  // Additive field for staff/operators support (docs/POS_POLICY_ENGINE.md
  // §14) — same independent-counter pattern as policiesVersion/
  // printTemplatesVersion. Bumped on every PosOperator create/update/
  // delete for this store; PosOperator itself lives in its own table
  // (below), not embedded here.
  staffVersion          Int  @default(1)

  @@index([tenantId])
  @@map("pos_settings")
}

// ============================================================
// POS STAFF / OPERATORS (docs/POS_POLICY_ENGINE.md §14)
// ============================================================

enum PosOperatorRole {
  CASHIER
  SENIOR_CASHIER
  ADMIN
}

// Deliberately its own entity, not a role/permission variant of User/Team —
// a cashier working a till has no login to the tenant-admin panel and no
// User row at all (docs/POS_POLICY_ENGINE.md §14). Store-scoped like
// PosDevice/PosSettings; `id` is a real CUID from this table, never an
// arbitrary string the till or store-admin client supplies. PIN/password
// auth is explicitly out of scope for this iteration — this is a roster +
// permissions list only.
model PosOperator {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId     String
  store       Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  role        PosOperatorRole
  permissions String[]        @default([])
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tenantId, storeId])
  @@map("pos_operators")
}

// ============================================================
// POS POLICY ENGINE (docs/POS_POLICY_ENGINE.md)
// ============================================================

enum PolicyScope {
  SALE
  REFUND
  SHIFT
  PAYMENT
  MARKING
  DISCOUNT
  CASHIER
  PRINT
}

enum PolicySeverity {
  BLOCK
  WARN
  REQUIRE_MANAGER
  REQUIRE_ACTION
  INFO
}

// Deliberately NOT tenant-scoped — global to the whole platform, managed
// centrally (docs/POS_POLICY_ENGINE.md §3.1/§11). A tenant has no write
// path to this model at all; that (plus till-side max-severity
// evaluation) is what makes "tenant can only tighten, never loosen a
// platform rule" hold structurally rather than needing to be validated.
model PlatformPolicy {
  id       String         @id @default(cuid())
  scope    PolicyScope
  severity PolicySeverity
  enabled  Boolean        @default(true)
  // Scope-specific matcher. For PAYMENT/MARKING rules keyed on product
  // category (e.g. the tobacco/alcohol cash-payment ban): matches on
  // Category.slug STRING VALUES, not Category.id. Category is
  // tenant-scoped (@@unique([tenantId, slug])) — a global rule can't FK
  // to any one tenant's specific category row, since there is no single
  // "the tobacco category" across tenants. slug is the only thing that
  // can plausibly recur as the same meaningful string across many
  // independently-created tenant catalogs, which is exactly what a
  // global rule needs to match against at evaluation time (the till
  // checks its OWN tenant's product -> category -> slug, a same-tenant
  // lookup, then compares the resulting string against this rule's
  // categorySlugs — never a cross-tenant reference). This relies on
  // tenants actually slugging equivalent categories consistently (e.g.
  // "tobacco", not "tabak-i-sigarety") — a real, unenforced convention,
  // not a hard guarantee; flagged as an open question in
  // docs/POS_POLICY_ENGINE.md §12 for the till-side matching
  // implementation (step 3+) to actually reckon with, not solved here.
  match    Json
  message  Json // { "ru": string, "uz": string }
  // Scope-specific fields that don't fit `match` (e.g. PAYMENT rules'
  // denyPayments: string[]) — same "loose bag, shape settles with real
  // usage" reasoning as `match` and as pos-sync's rawFiscalPayload.
  extra    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
  @@map("platform_policies")
}

// Global version counter — same atomic-cached-counter pattern as
// Counterparty.currentDebt/CounterpartyLedger (docs/B2B_COUNTERPARTIES.md
// §7) and applyStockDelta()/StockLedgerEntry (pos-sync/routes.ts),
// applied to a single global counter instead of a per-row one.
// "Singleton" is an application-level convention (code always
// reads/writes the one row via a well-known id, upserting it into
// existence on first write) — not a database-enforced constraint;
// Postgres has no native "exactly one row" constraint, and adding one
// would be over-engineering for what's fundamentally one counter.
model PlatformPolicyVersion {
  id      String @id @default(cuid())
  version Int    @default(1)

  @@map("platform_policy_version")
}

model SyncCursor {
  id                 String    @id @default(cuid())
  deviceId           String    @unique
  device             PosDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  lastCatalogVersion Int       @default(0)
  lastSyncAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("sync_cursors")
}

// Independent from StockMovement (Sellgram Commerce's own stock audit log,
// see §308). StockLedgerEntry is the POS-side equivalent, fed by POS sale/
// adjustment events — deliberately not unified with StockMovement (see
// docs/SBGCLOUD_ARCHITECTURE.md §12).
model StockLedgerEntry {
  id         String            @id @default(cuid())
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId  String
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  delta      Int
  reason     StockLedgerReason
  sourceType String
  sourceId   String?
  createdAt  DateTime          @default(now())

  @@index([tenantId, productId, createdAt])
  @@map("stock_ledger_entries")
}
