generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum UserRole {
  OWNER
  MANAGER
  OPERATOR
  MARKETER
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  MANUAL_TRANSFER
  TELEGRAM
  CLICK
  PAYME
  UZUM
  STRIPE
  CUSTOM
}

enum PaymentProvider {
  CASH
  MANUAL_TRANSFER
  TELEGRAM
  CLICK
  PAYME
  UZUM
  STRIPE
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum DeliveryType {
  PICKUP
  LOCAL
  NATIONAL
}

enum LoyaltyTxnType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
}

enum POStatus {
  DRAFT
  ORDERED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum ScheduledFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ============================================================
// TENANT & AUTH
// ============================================================

model Tenant {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  // Set/cleared only by system-admin block/unblock (service.ts
  // blockSystemTenant/unblockSystemTenant) — a distinct signal from
  // deletedAt (soft-delete) or plan expiry, consumed by POS Sync's
  // heartbeat licenseStatus (apps/api/src/lib/billing.ts getLicenseStatus).
  blockedAt     DateTime?

  users              User[]
  stores             Store[]
  products           Product[]
  categories         Category[]
  customers          Customer[]
  orders             Order[]
  deliveryZones      DeliveryZone[]
  loyaltyConfig      LoyaltyConfig?
  purchaseOrders     PurchaseOrder[]
  suppliers          Supplier[]
  promoCodes         PromoCode[]
  invoices           Invoice[]
  paymentMethods     StorePaymentMethod[]
  broadcasts         BroadcastCampaign[]
  scheduledReports   ScheduledReport[]
  auditLogs          TenantAuditLog[]
  banners            Banner[]
  apiKeys            ApiKey[]
  webhooks           Webhook[]
  posDevices         PosDevice[]
  catalogSnapshots   CatalogSnapshot[]
  stockLedgerEntries StockLedgerEntry[]
  posSettings        PosSettings[]
  saleEvents         SaleEvent[]
  stockEvents        StockEvent[]
  fiscalEvents       FiscalEvent[]
  shiftEvents        ShiftEvent[]
  cloudCommands      CloudCommand[]

  @@map("tenants")
}

model User {
  id                        String    @id @default(cuid())
  tenantId                  String
  tenant                    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                     String    @unique
  passwordHash              String
  name                      String
  role                      UserRole  @default(OWNER)
  permissions               Json?
  adminTelegramId           BigInt? // For receiving order notifications in Telegram
  telegramLinkCode          String?
  telegramLinkCodeExpiresAt DateTime?
  passwordResetToken        String?   @unique
  passwordResetExpiry       DateTime?
  isActive                  Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  broadcastsCreated BroadcastCampaign[] @relation("BroadcastCreatedBy")

  @@index([tenantId])
  @@map("users")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  prefix     String
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  events    Json // string[] e.g. ["order.created","order.status_changed"]
  secret    String // whsec_xxx for HMAC-SHA256 signing
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("webhooks")
}

// ============================================================
// STORE (Telegram Bot)
// ============================================================

model Store {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  botToken       String // AES-256-GCM encrypted
  botUsername    String?
  webhookSecret  String   @default(cuid())
  welcomeMessage String?  @default("Welcome! Tap the button below to open the store.")
  miniAppUrl     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders           Order[]
  deliveryZones    DeliveryZone[]
  paymentMethods   StorePaymentMethod[]
  broadcasts       BroadcastCampaign[]
  posDevices       PosDevice[]
  catalogSnapshots CatalogSnapshot[]
  posSettings      PosSettings?
  saleEvents       SaleEvent[]
  stockEvents      StockEvent[]
  fiscalEvents     FiscalEvent[]
  shiftEvents      ShiftEvent[]

  @@index([tenantId])
  @@map("stores")
}

// ============================================================
// CATALOG
// ============================================================

model Category {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  sortOrder Int        @default(0)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  products   Product[]
  attributes CategoryAttribute[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

model CategoryAttribute {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([categoryId])
  @@map("category_attributes")
}

model Product {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  description   String?
  price         Decimal   @db.Decimal(12, 2)
  costPrice     Decimal?  @db.Decimal(12, 2)
  currency      String    @default("UZS")
  sku           String?
  stockQty      Int       @default(0)
  lowStockAlert Int       @default(5)
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  images             ProductImage[]
  variants           ProductVariant[]
  orderItems         OrderItem[]
  poItems            PurchaseOrderItem[]
  wishlistItems      WishlistItem[]
  stockMovements     StockMovement[]
  stockLedgerEntries StockLedgerEntry[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, isActive])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)

  @@map("product_images")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sku       String?
  price     Decimal? @db.Decimal(12, 2)
  stockQty  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  orderItems OrderItem[]

  @@map("product_variants")
}

model StockMovement {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  delta     Int
  qtyBefore Int
  qtyAfter  Int
  note      String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("stock_movements")
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  telegramId    BigInt
  telegramUser  String?
  firstName     String?
  lastName      String?
  languageCode  String?
  phone         String?
  loyaltyPoints Int      @default(0)
  totalSpent    Decimal  @default(0) @db.Decimal(12, 2)
  ordersCount   Int      @default(0)
  tags          String[] @default([])
  note          String?
  referralCode  String?  @unique
  referredBy    String?
  botBlocked    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders              Order[]
  loyaltyTxns         LoyaltyTransaction[]
  cartItems           CartItem[]
  broadcastRecipients BroadcastRecipient[]
  wishlistItems       WishlistItem[]
  addresses           CustomerAddress[]

  @@unique([tenantId, telegramId])
  @@index([tenantId])
  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenantId   String
  label      String   @default("home")
  address    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@map("customer_addresses")
}

// ============================================================
// CART (server-side)
// ============================================================

model CartItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  storeId    String
  productId  String
  variantId  String?
  qty        Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, storeId, productId, variantId])
  @@index([customerId, storeId])
  @@map("cart_items")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId            String
  store              Store               @relation(fields: [storeId], references: [id])
  orderNumber        Int
  customerId         String?
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status             OrderStatus         @default(NEW)
  paymentMethod      PaymentMethod       @default(CASH_ON_DELIVERY)
  paymentMethodId    String?
  paymentMethodRef   StorePaymentMethod? @relation("OrderToStorePaymentMethod", fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentMethodCode  String?
  paymentMethodTitle String?
  paymentMeta        Json?
  paymentStatus      PaymentStatus       @default(PENDING)

  // Delivery
  deliveryType    DeliveryType
  deliveryZoneId  String?
  deliveryZone    DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  deliveryAddress String?
  deliveryPrice   Decimal?      @db.Decimal(12, 2)
  trackingNumber  String?

  // Totals
  subtotal          Decimal    @db.Decimal(12, 2)
  discount          Decimal    @default(0) @db.Decimal(12, 2)
  loyaltyDiscount   Decimal    @default(0) @db.Decimal(12, 2)
  loyaltyPointsUsed Int        @default(0)
  promoDiscount     Decimal    @default(0) @db.Decimal(12, 2)
  promoCodeId       String?
  promoCode         PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  total             Decimal    @db.Decimal(12, 2)

  note         String?
  cancelReason String?
  refundAmount Decimal? @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items         OrderItem[]
  statusHistory OrderStatusLog[]
  review        OrderReview?

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, paymentStatus])
  @@index([paymentMethodId])
  @@index([tenantId, storeId])
  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
  @@index([deliveryZoneId])
  @@map("orders")
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  name        String
  variantName String?
  price       Decimal         @db.Decimal(12, 2)
  qty         Int
  total       Decimal         @db.Decimal(12, 2)

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

model OrderStatusLog {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  note       String?
  createdAt  DateTime     @default(now())

  @@index([orderId])
  @@map("order_status_logs")
}

model OrderReview {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  tenantId   String
  rating     Int
  comment    String?
  hidden     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, hidden], name: "order_reviews_hidden_idx")
  @@map("order_reviews")
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId   String
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("wishlist_items")
}

model PromoCode {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String
  type           String    @default("PERCENT") // PERCENT | FIXED
  value          Decimal   @db.Decimal(12, 2)
  minOrderAmount Decimal?  @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  orders         Order[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("promo_codes")
}

model PaymentWebhookEvent {
  id          String   @id @default(cuid())
  orderId     String
  eventId     String
  provider    String
  processedAt DateTime @default(now())

  @@unique([orderId, eventId])
  @@index([orderId])
  @@map("payment_webhook_events")
}

model Banner {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String?
  imageUrl  String
  linkUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("banners")
}

// ============================================================
// DELIVERY
// ============================================================

model DeliveryZone {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  name      String
  price     Decimal  @db.Decimal(12, 2)
  freeFrom  Decimal? @db.Decimal(12, 2)
  etaMin    Int? // minutes
  etaMax    Int?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  orders Order[]

  @@index([tenantId])
  @@map("delivery_zones")
}

// ============================================================
// LOYALTY
// ============================================================

model LoyaltyConfig {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  tenant              Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isEnabled           Boolean @default(false)
  pointsPerUnit       Int     @default(1)
  unitAmount          Int     @default(1000) // 1 point per 1000 UZS
  pointValue          Int     @default(100) // 1 point = 100 UZS
  maxDiscountPct      Int     @default(30)
  minPointsToRedeem   Int     @default(100)
  tiers               Json? // [{name,nameUz,minSpend,multiplier,color}]
  referralEnabled     Boolean @default(false)
  referralBonus       Int     @default(500) // points to referrer
  referralFriendBonus Int     @default(0) // points to invited friend

  @@map("loyalty_configs")
}

model LoyaltyTransaction {
  id           String         @id @default(cuid())
  customerId   String
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenantId     String
  type         LoyaltyTxnType
  points       Int
  balanceAfter Int
  orderId      String?
  description  String?
  createdAt    DateTime       @default(now())

  @@index([customerId, createdAt(sort: Desc)])
  @@index([tenantId])
  @@map("loyalty_transactions")
}

// ============================================================
// PROCUREMENT
// ============================================================

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  note        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  poNumber     Int
  supplierName String
  status       POStatus  @default(DRAFT)
  currency     String    @default("USD")
  fxRate       Decimal?  @db.Decimal(12, 6)
  shippingCost Decimal   @default(0) @db.Decimal(12, 2)
  customsCost  Decimal   @default(0) @db.Decimal(12, 2)
  totalCost    Decimal   @default(0) @db.Decimal(12, 2)
  totalLanded  Decimal   @default(0) @db.Decimal(12, 2)
  note         String?
  orderedAt    DateTime?
  receivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  qty             Int
  unitCost        Decimal       @db.Decimal(12, 2)
  totalCost       Decimal       @db.Decimal(12, 2)
  qtyReceived     Int           @default(0)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// ============================================================
// BILLING (manual invoices)
// ============================================================

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
  EXPIRED
}

enum BroadcastStatus {
  DRAFT
  QUEUED
  SENDING
  SENT
  FAILED
}

enum BroadcastTargetType {
  ALL
  SELECTED
}

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan        Plan
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("UZS")
  status      InvoiceStatus @default(PENDING)
  paymentRef  String? // Transaction ID from bank transfer
  paymentNote String? // Owner's note about payment
  confirmedBy String? // Admin user ID who confirmed
  confirmedAt DateTime?
  expiresAt   DateTime // Invoice expires after 48h
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

model StorePaymentMethod {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider     PaymentProvider @default(CUSTOM)
  code         String
  title        String
  description  String?
  instructions String?
  isActive     Boolean         @default(true)
  isDefault    Boolean         @default(false)
  sortOrder    Int             @default(0)
  meta         Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  orders Order[] @relation("OrderToStorePaymentMethod")

  @@unique([storeId, code])
  @@index([tenantId, storeId, isActive])
  @@map("store_payment_methods")
}

model BroadcastCampaign {
  id              String              @id @default(cuid())
  tenantId        String
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId         String
  store           Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User                @relation("BroadcastCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  title           String?
  message         String
  targetType      BroadcastTargetType
  status          BroadcastStatus     @default(DRAFT)
  totalRecipients Int                 @default(0)
  sentCount       Int                 @default(0)
  failedCount     Int                 @default(0)
  createdAt       DateTime            @default(now())
  sentAt          DateTime?

  recipients BroadcastRecipient[]

  @@index([tenantId, storeId, createdAt])
  @@index([status])
  @@map("broadcast_campaigns")
}

model BroadcastRecipient {
  id         String            @id @default(cuid())
  campaignId String
  campaign   BroadcastCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  telegramId BigInt
  success    Boolean           @default(false)
  error      String?
  sentAt     DateTime?

  @@unique([campaignId, customerId])
  @@index([campaignId, success])
  @@map("broadcast_recipients")
}

model SystemAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("system_admins")
}

model TenantAuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId   String?
  action    String
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("tenant_audit_logs")
}

enum SystemAuditAction {
  TENANT_PLAN_UPDATED
  INVOICE_CONFIRMED
  INVOICE_REJECTED
}

model SystemAuditLog {
  id         String            @id @default(cuid())
  action     SystemAuditAction
  actorId    String?
  actorEmail String?
  targetType String
  targetId   String
  details    Json?
  createdAt  DateTime          @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("system_audit_logs")
}

model SystemSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model ScheduledReport {
  id         String             @id @default(cuid())
  tenantId   String
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportType String // top-products | revenue | categories | customers
  periodDays Int
  frequency  ScheduledFrequency
  isActive   Boolean            @default(true)
  lastSentAt DateTime?
  nextRunAt  DateTime
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([tenantId])
  @@index([nextRunAt, isActive])
  @@map("scheduled_reports")
}

// ============================================================
// POS SYNC (SBGCloud) — see docs/SBGCLOUD_ARCHITECTURE.md
// First wave only: device identity, activation, catalog snapshot, stock
// ledger. Sale/fiscal/shift ingestion intentionally NOT modeled yet —
// pending a confirmed fiscal integration partner for Uzbekistan.
// ============================================================

enum PosDeviceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REVOKED
}

enum DeviceActivationStatus {
  PENDING
  CONFIRMED
  EXPIRED
}

enum StockLedgerReason {
  POS_SALE
  POS_ADJUSTMENT
  RESTOCK
  OTHER
}

model PosDevice {
  id           String          @id @default(cuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId      String
  store        Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name         String
  deviceType   String
  status       PosDeviceStatus @default(PENDING)
  // Device credential, same hash-only pattern as ApiKey.keyHash/prefix —
  // the raw key is shown once at activation time and never stored.
  apiKeyHash   String?         @unique
  apiKeyPrefix String?
  // Minted alongside apiKeyHash at activation (docs/POS_SYNC_API.md §7),
  // but there is no refresh-verification endpoint yet — accessToken
  // (apiKeyHash) is treated as long-lived in practice until one exists.
  refreshTokenHash   String?   @unique
  refreshTokenPrefix String?
  // Device-reported at activation, kept separate from the admin-set
  // name/deviceType above (which stay authoritative for fleet display) —
  // deviceFingerprint is used only for the reactivation-anomaly check.
  deviceFingerprint  String?
  reportedDeviceName String?
  reportedDeviceType String?
  appVersion         String?
  // PUBLIC device identifier (not a secret — safe to log), sent by the
  // device at /activate the same way as deviceFingerprint — confirmed
  // production flow with the SBG Lite POS Android team (their client
  // derives it from local config). Checked as a PAIR with Authorization:
  // Bearer on every other authenticated endpoint (docs/POS_SYNC_API.md
  // §4/§22): Bearer remains the sole real auth factor; a request whose
  // token was issued for a different deviceCode is rejected, not just a
  // present-but-unrelated header. Unique per tenant (two devices of one
  // tenant can't share a code; different tenants may reuse the same
  // dev-style value, e.g. "POS-1") — nullable only for pre-existing rows
  // that activated before this column existed.
  deviceCode   String?
  lastSeenAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  activations DeviceActivation[]
  syncCursor  SyncCursor?
  saleEvents  SaleEvent[]
  stockEvents StockEvent[]
  fiscalEvents FiscalEvent[]
  shiftEvents  ShiftEvent[]
  cloudCommands CloudCommand[]

  @@unique([tenantId, deviceCode])
  @@index([tenantId, storeId])
  @@map("pos_devices")
}

model DeviceActivation {
  id             String                 @id @default(cuid())
  deviceId       String
  device         PosDevice              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  activationCode String                 @unique
  status         DeviceActivationStatus @default(PENDING)
  expiresAt      DateTime
  confirmedAt    DateTime?
  createdAt      DateTime               @default(now())

  @@index([deviceId])
  @@map("device_activations")
}

model CatalogSnapshot {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  version   Int
  payload   Json
  createdAt DateTime @default(now())

  @@index([tenantId, storeId, version])
  @@map("catalog_snapshots")
}

enum SaleEventType {
  SALE_CREATED
  SALE_PAID
  SALE_FISCALIZED
  SALE_COMPLETED
  SALE_CANCELLED
  SALE_REFUNDED
  SALE_FISCAL_UNKNOWN
}

enum SaleEventStatus {
  FISCALIZED
  FISCAL_UNKNOWN
  COMPLETED
  CANCELLED
  REFUNDED
}

// Append-only cloud-side mirror of sales that already completed locally
// (docs/POS_SYNC_API.md §5/§11). Never mutated — corrections arrive as new
// events (SALE_CANCELLED, SALE_REFUNDED, FISCAL_RECOVERED), never edits.
// payloadHash + the unique idempotencyKey implement §5: an identical replay
// returns the stored result; a different payload under the same key is a
// client bug rejected with 409 IDEMPOTENCY_KEY_REUSED.
model SaleEvent {
  id             String          @id @default(cuid())
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId       String
  device         PosDevice       @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  localSaleId    String
  localShiftId   String
  eventType      SaleEventType
  status         SaleEventStatus
  receiptNumber  Int
  idempotencyKey String          @unique
  payloadHash    String
  occurredAt     DateTime
  payload        Json
  // Per-item ingest warnings (UNKNOWN_PRODUCT etc, docs/POS_SYNC_API.md
  // §11/§18) — stored, not recomputed, so a §5 replay returns the exact
  // same body the first attempt got.
  warnings       Json
  createdAt      DateTime        @default(now())

  @@index([tenantId, storeId, localSaleId])
  @@index([tenantId, occurredAt])
  @@map("sale_events")
}

// Non-sale stock movement reported by a till (docs/POS_SYNC_API.md §14) —
// cashier stock-count correction or manual restock. Append-only, same §5
// idempotency semantics as SaleEvent. productId deliberately has NO foreign
// key: the event must survive referencing a product unknown to Cloud
// (§18 accept-don't-reject) — the derived StockLedgerEntry row (which does
// FK to Product) is simply skipped in that case, with a stored warning.
model StockEvent {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId       String
  device         PosDevice         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  productId      String
  variantId      String?
  delta          Int
  // Shares StockLedgerReason with the ledger, but the API layer only
  // accepts POS_ADJUSTMENT/RESTOCK/OTHER — POS_SALE rows are exclusively
  // derived from sale events (§14).
  reason         StockLedgerReason
  idempotencyKey String            @unique
  payloadHash    String
  occurredAt     DateTime
  note           String?
  warnings       Json
  createdAt      DateTime          @default(now())

  @@index([tenantId, storeId, productId])
  @@map("stock_events")
}

enum FiscalEventType {
  FISCAL_STARTED
  FISCAL_SUCCESS
  FISCAL_FAILED
  FISCAL_UNKNOWN
}

enum FiscalReceiptType {
  SALE
  REFUND
}

// Cloud-side mirror of a fiscal-module receipt lifecycle, per the real SBG
// Lite POS Android contract (fiscal/shift/commands v1, 2026-07-04) — not
// the earlier speculative shape in docs/pos-sync/schemas/fiscal-event
// .schema.json §12 (superseded, see doc update). Append-only: a device
// reports FISCAL_STARTED, then later FISCAL_SUCCESS/FAILED/UNKNOWN for the
// same aggregateId as new rows, never edits of the prior one — an
// already-stored FISCAL_UNKNOWN/FAILED is never rewritten into a success.
// Same tenantId/storeId denormalization pattern as SaleEvent/StockEvent
// even though both are derivable via device — kept for query/index parity.
// Status-shaped fields (fiscalStatus/printStatus/ofdStatus) are plain
// strings, not Prisma enums — the source contract does not give an
// exhaustive value list and firmware may add values without a migration.
// receiptNumber/originalReceiptNumber/fiscalReceiptNumber are String
// because the real contract sends either an Int or a String for these
// depending on receipt type (see doc §2.2 vs §2.3) — normalized to string.
model FiscalEvent {
  id             String            @id @default(cuid())
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId       String
  device         PosDevice         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  eventId        String
  eventType      FiscalEventType
  aggregateType  String
  aggregateId    String
  idempotencyKey String
  schemaVersion  Int
  shiftNumber    Int
  localReceiptId String
  daemonJournalId String?
  receiptNumber  String?
  receiptType    FiscalReceiptType?
  originalLocalReceiptId String?
  originalReceiptNumber  String?
  totalAmount    Int
  currency       String
  payments       Json
  items          Json
  createdAtMs    DateTime
  fiscalizedAtMs DateTime?
  fiscalStatus   String
  printStatus    String
  fiscalReceiptNumber String?
  fiscalSign     String?
  fiscalQr       String?
  ofdStatus      String?
  errorCode      String?
  errorMessage   String?
  rawDaemonResponse Json
  rawFiscalPayload  Json?
  payloadHash    String
  createdAt      DateTime          @default(now())

  @@unique([deviceId, eventId])
  @@index([deviceId, localReceiptId])
  @@index([deviceId, receiptNumber])
  @@index([deviceId, receiptType, idempotencyKey])
  @@index([deviceId, shiftNumber])
  @@map("fiscal_events")
}

enum ShiftEventType {
  SHIFT_OPENED
  SHIFT_CLOSED
}

// Cloud-side mirror of a till shift lifecycle, per the real SBG Lite POS
// Android contract §3. Same append-only / eventId-keyed idempotency model
// as FiscalEvent — see that model's comment.
model ShiftEvent {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId        String
  store          Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId       String
  device         PosDevice      @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  eventId        String
  eventType      ShiftEventType
  aggregateType  String
  aggregateId    String
  idempotencyKey String
  schemaVersion  Int
  shiftNumber    Int
  shiftState     String
  openedAtMs     DateTime?
  closedAtMs     DateTime?
  zReportStatus  String
  rawDaemonResponse Json
  rawShiftPayload   Json
  payloadHash    String
  createdAt      DateTime       @default(now())

  @@unique([deviceId, eventId])
  @@index([deviceId, shiftNumber])
  @@map("shift_events")
}

enum CloudCommandType {
  PING
  REFRESH_CATALOG
  REFRESH_SETTINGS
  SHOW_MESSAGE
}

enum CloudCommandStatus {
  PENDING
  ACKED
}

enum CloudCommandAckStatus {
  DONE
  FAILED
  IGNORED
  RETRY_LATER
}

// A narrow, non-blocking channel for Cloud to signal a device (§6 of the
// real contract) — never a channel for anything that could create a
// receipt/payment/refund/fiscal operation or gate a local sale (§9 of
// docs/SBGCLOUD_ARCHITECTURE.md). Nothing in this codebase creates
// CloudCommand rows yet (no admin UI wired up) — GET /commands will
// legitimately return an empty list until that exists; this is the
// polling/ack surface only.
model CloudCommand {
  id         String                  @id @default(cuid())
  tenantId   String
  tenant     Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deviceId   String
  device     PosDevice               @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  type       CloudCommandType
  payload    Json
  status     CloudCommandStatus      @default(PENDING)
  createdAt  DateTime                @default(now())
  ackedAt    DateTime?
  ackStatus  CloudCommandAckStatus?
  ackMessage String?

  @@index([deviceId, status])
  @@map("cloud_commands")
}

// Store-scoped POS operational settings (docs/POS_SYNC_API.md §10).
// payload is the eight-key settings body (taxProfile, paymentMethods, ...)
// with intentionally unconstrained internals — the nested shapes depend on
// the eventual Uzbekistan fiscal integration partner and are not modeled
// as columns on purpose. version bumps on every store-admin write.
model PosSettings {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String   @unique
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  version   Int      @default(1)
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("pos_settings")
}

model SyncCursor {
  id                 String    @id @default(cuid())
  deviceId           String    @unique
  device             PosDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  lastCatalogVersion Int       @default(0)
  lastSyncAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("sync_cursors")
}

// Independent from StockMovement (Sellgram Commerce's own stock audit log,
// see §308). StockLedgerEntry is the POS-side equivalent, fed by POS sale/
// adjustment events — deliberately not unified with StockMovement (see
// docs/SBGCLOUD_ARCHITECTURE.md §12).
model StockLedgerEntry {
  id         String            @id @default(cuid())
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId  String
  product    Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId  String?
  delta      Int
  reason     StockLedgerReason
  sourceType String
  sourceId   String?
  createdAt  DateTime          @default(now())

  @@index([tenantId, productId, createdAt])
  @@map("stock_ledger_entries")
}
