generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum UserRole {
  OWNER
  MANAGER
  OPERATOR
  MARKETER
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum SalesChannel {
  TELEGRAM
  B2B
}

enum PaymentMethod {
  CASH_ON_DELIVERY
  MANUAL_TRANSFER
  TELEGRAM
  CLICK
  PAYME
  UZUM
  STRIPE
  CUSTOM
}

enum PaymentProvider {
  CASH
  MANUAL_TRANSFER
  TELEGRAM
  CLICK
  PAYME
  UZUM
  STRIPE
  CUSTOM
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

enum DeliveryType {
  PICKUP
  LOCAL
  NATIONAL
}

enum LoyaltyTxnType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
}

enum POStatus {
  DRAFT
  ORDERED
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum ScheduledFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ============================================================
// TENANT & AUTH
// ============================================================

model Tenant {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  // Set/cleared only by system-admin block/unblock (service.ts
  // blockSystemTenant/unblockSystemTenant) — a distinct signal from
  // deletedAt (soft-delete) or plan expiry, consumed by POS Sync's
  // heartbeat licenseStatus (apps/api/src/lib/billing.ts getLicenseStatus).
  blockedAt     DateTime?
  // Plain per-tenant toggle for the B2B/counterparties module — NOT
  // plan-gated (unlike posEnabled, which lives in PLANS.limits and is
  // enforced via planGuard()). Any tenant on any plan can turn this on
  // (docs/B2B_COUNTERPARTIES.md §9).
  b2bEnabled    Boolean   @default(false)

  users              User[]
  stores             Store[]
  products           Product[]
  categories         Category[]
  customers          Customer[]
  orders             Order[]
  deliveryZones      DeliveryZone[]
  loyaltyConfig      LoyaltyConfig?
  purchaseOrders     PurchaseOrder[]
  suppliers          Supplier[]
  promoCodes         PromoCode[]
  invoices           Invoice[]
  paymentMethods     StorePaymentMethod[]
  broadcasts         BroadcastCampaign[]
  scheduledReports   ScheduledReport[]
  auditLogs          TenantAuditLog[]
  banners            Banner[]
  apiKeys            ApiKey[]
  webhooks           Webhook[]
  posDevices         PosDevice[]
  catalogSnapshots   CatalogSnapshot[]
  stockLedgerEntries StockLedgerEntry[]
  posSettings        PosSettings[]
  saleEvents         SaleEvent[]
  stockEvents        StockEvent[]
  fiscalEvents       FiscalEvent[]
  shiftEvents        ShiftEvent[]
  cloudCommands      CloudCommand[]
  counterparties     Counterparty[]
  counterpartyLedger CounterpartyLedger[]
  posOperators       PosOperator[]

  @@map("tenants")
}

model User {
  id                        String    @id @default(cuid())
  tenantId                  String
  tenant                    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                     String    @unique
  passwordHash              String
  name                      String
  role                      UserRole  @default(OWNER)
  permissions               Json?
  adminTelegramId           BigInt? // For receiving order notifications in Telegram
  telegramLinkCode          String?
  telegramLinkCodeExpiresAt DateTime?
  passwordResetToken        String?   @unique
  passwordResetExpiry       DateTime?
  isActive                  Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  broadcastsCreated BroadcastCampaign[] @relation("BroadcastCreatedBy")

  @@index([tenantId])
  @@map("users")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  prefix     String
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("api_keys")
}

model Webhook {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url       String
  events    Json // string[] e.g. ["order.created","order.status_changed"]
  secret    String // whsec_xxx for HMAC-SHA256 signing
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@map("webhooks")
}

// ============================================================
// STORE (Telegram Bot)
// ============================================================

model Store {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  botToken       String // AES-256-GCM encrypted
  botUsername    String?
  webhookSecret  String   @default(cuid())
  welcomeMessage String?  @default("Welcome! Tap the button below to open the store.")
  miniAppUrl     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  orders           Order[]
  deliveryZones    DeliveryZone[]
  paymentMethods   StorePaymentMethod[]
  broadcasts       BroadcastCampaign[]
  posDevices       PosDevice[]
  catalogSnapshots CatalogSnapshot[]
  posSettings      PosSettings?
  saleEvents       SaleEvent[]
  stockEvents      StockEvent[]
  fiscalEvents     FiscalEvent[]
  shiftEvents      ShiftEvent[]
  posOperators     PosOperator[]

  @@index([tenantId])
  @@map("stores")
}

// ============================================================
// CATALOG
// ============================================================

model Category {
  id        String     @id @default(cuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  sortOrder Int        @default(0)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  products   Product[]
  attributes CategoryAttribute[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

model CategoryAttribute {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([categoryId])
  @@map("category_attributes")
}

model Product {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name          String
  description   String?
  price         Decimal   @db.Decimal(12, 2)
  costPrice     Decimal?  @db.Decimal(12, 2)
  currency      String    @default("UZS")
  sku           String?
  // Uzbekistan fiscal/marking codes (docs/POS_SYNC_API.md fiscal-events;
  // POS receipt templates already reference these via the
  // showMxik/showPackageCode flags in docs/POS_POLICY_ENGINE.md, but
  // Product itself had no columns to source the values from). Added
  // directly here, same as sku/costPrice, rather than as a separate
  // ProductUzProfile extension table (docs/SBGCLOUD_ARCHITECTURE.md
  // §8/§12's "future data model" sketch) — two plain optional strings
  // don't warrant a one-to-one extension table.
  mxikCode      String?
  packageCode   String?
  stockQty      Int       @default(0)
  lowStockAlert Int       @default(5)
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  images             ProductImage[]
  variants           ProductVariant[]
  orderItems         OrderItem[]
  poItems            PurchaseOrderItem[]
  wishlistItems      WishlistItem[]
  stockMovements     StockMovement[]
  stockLedgerEntries StockLedgerEntry[]
  counterpartyPrices CounterpartyPrice[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, isActive])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)

  @@map("product_images")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  sku       String?
  price     Decimal? @db.Decimal(12, 2)
  stockQty  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  orderItems OrderItem[]
  counterpartyPrices CounterpartyPrice[]

  @@map("product_variants")
}

model StockMovement {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  delta     Int
  qtyBefore Int
  qtyAfter  Int
  note      String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("stock_movements")
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  telegramId    BigInt
  telegramUser  String?
  firstName     String?
  lastName      String?
  languageCode  String?
  phone         String?
  loyaltyPoints Int      @default(0)
  totalSpent    Decimal  @default(0) @db.Decimal(12, 2)
  ordersCount   Int      @default(0)
  tags          String[] @default([])
  note          String?
  referralCode  String?  @unique
  referredBy    String?
  botBlocked    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders              Order[]
  loyaltyTxns         LoyaltyTransaction[]
  cartItems           CartItem[]
  broadcastRecipients BroadcastRecipient[]
  wishlistItems       WishlistItem[]
  addresses           CustomerAddress[]

  @@unique([tenantId, telegramId])
  @@index([tenantId])
  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenantId   String
  label      String   @default("home")
  address    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([customerId])
  @@map("customer_addresses")
}

// ============================================================
// CART (server-side)
// ============================================================

model CartItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  storeId    String
  productId  String
  variantId  String?
  qty        Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([customerId, storeId, productId, variantId])
  @@index([customerId, storeId])
  @@map("cart_items")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id                 String              @id @default(cuid())
  tenantId           String
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId            String
  store              Store               @relation(fields: [storeId], references: [id])
  orderNumber        Int
  customerId         String?
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  // B2B/counterparties module (docs/B2B_COUNTERPARTIES.md §6) — salesChannel
  // defaults to TELEGRAM so every existing row stays correct with no
  // backfill. counterpartyId is the B2B counterpart to customerId; the
  // business rule (exactly one of customerId/counterpartyId set,
  // depending on salesChannel) is enforced in application code, not the
  // schema — Prisma/Postgres can't express that conditional constraint.
  salesChannel       SalesChannel        @default(TELEGRAM)
  counterpartyId     String?
  counterparty       Counterparty?       @relation(fields: [counterpartyId], references: [id])
  status             OrderStatus         @default(NEW)
  paymentMethod      PaymentMethod       @default(CASH_ON_DELIVERY)
  paymentMethodId    String?
  paymentMethodRef   StorePaymentMethod? @relation("OrderToStorePaymentMethod", fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentMethodCode  String?
  paymentMethodTitle String?
  paymentMeta        Json?
  paymentStatus      PaymentStatus       @default(PENDING)

  // Delivery
  deliveryType    DeliveryType
  deliveryZoneId  String?
  deliveryZone    DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  deliveryAddress String?
  deliveryPrice   Decimal?      @db.Decimal(12, 2)
  trackingNumber  String?

  // Totals
  subtotal          Decimal    @db.Decimal(12, 2)
  discount          Decimal    @default(0) @db.Decimal(12, 2)
  loyaltyDiscount   Decimal    @default(0) @db.Decimal(12, 2)
  loyaltyPointsUsed Int        @default(0)
  promoDiscount     Decimal    @default(0) @db.Decimal(12, 2)
  promoCodeId       String?
  promoCode         PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  total             Decimal    @db.Decimal(12, 2)

  note         String?
  cancelReason String?
  refundAmount Decimal? @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items                     OrderItem[]
  statusHistory             OrderStatusLog[]
  review                    OrderReview?
  counterpartyLedgerEntries CounterpartyLedger[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, paymentStatus])
  @@index([paymentMethodId])
  @@index([tenantId, storeId])
  @@index([tenantId, customerId])
  @@index([tenantId, counterpartyId])
  @@index([tenantId, createdAt])
  @@index([deliveryZoneId])
  @@map("orders")
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  name        String
  variantName String?
  price       Decimal         @db.Decimal(12, 2)
  qty         Int
  total       Decimal         @db.Decimal(12, 2)

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

model OrderStatusLog {
  id         String       @id @default(cuid())
  orderId    String
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  note       String?
  createdAt  DateTime     @default(now())

  @@index([orderId])
  @@map("order_status_logs")
}

model OrderReview {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  tenantId   String
  rating     Int
  comment    String?
  hidden     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, hidden], name: "order_reviews_hidden_idx")
  @@map("order_reviews")
}

model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenantId   String
  createdAt  DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("wishlist_items")
}

model PromoCode {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code           String
  type           String    @default("PERCENT") // PERCENT | FIXED
  value          Decimal   @db.Decimal(12, 2)
  minOrderAmount Decimal?  @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int       @default(0)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  orders         Order[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("promo_codes")
}

model PaymentWebhookEvent {
  id          String   @id @default(cuid())
  orderId     String
  eventId     String
  provider    String
  processedAt DateTime @default(now())

  @@unique([orderId, eventId])
  @@index([orderId])
  @@map("payment_webhook_events")
}

model Banner {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title     String?
  imageUrl  String
  linkUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("banners")
}

// ============================================================
// DELIVERY
// ============================================================

model DeliveryZone {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  name      String
  price     Decimal  @db.Decimal(12, 2)
  freeFrom  Decimal? @db.Decimal(12, 2)
  etaMin    Int? // minutes
  etaMax    Int?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)

  orders Order[]

  @@index([tenantId])
  @@map("delivery_zones")
}

// ============================================================
// LOYALTY
// ============================================================

model LoyaltyConfig {
  id                  String  @id @default(cuid())
  tenantId            String  @unique
  tenant              Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isEnabled           Boolean @default(false)
  pointsPerUnit       Int     @default(1)
  unitAmount          Int     @default(1000) // 1 point per 1000 UZS
  pointValue          Int     @default(100) // 1 point = 100 UZS
  maxDiscountPct      Int     @default(30)
  minPointsToRedeem   Int     @default(100)
  tiers               Json? // [{name,nameUz,minSpend,multiplier,color}]
  referralEnabled     Boolean @default(false)
  referralBonus       Int     @default(500) // points to referrer
  referralFriendBonus Int     @default(0) // points to invited friend

  @@map("loyalty_configs")
}

model LoyaltyTransaction {
  id           String         @id @default(cuid())
  customerId   String
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenantId     String
  type         LoyaltyTxnType
  points       Int
  balanceAfter Int
  orderId      String?
  description  String?
  createdAt    DateTime       @default(now())

  @@index([customerId, createdAt(sort: Desc)])
  @@index([tenantId])
  @@map("loyalty_transactions")
}

// ============================================================
// PROCUREMENT
// ============================================================

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  note        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseOrders PurchaseOrder[]
  counterparty   Counterparty?

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  poNumber     Int
  supplierName String
  status       POStatus  @default(DRAFT)
  currency     String    @default("USD")
  fxRate       Decimal?  @db.Decimal(12, 6)
  shippingCost Decimal   @default(0) @db.Decimal(12, 2)
  customsCost  Decimal   @default(0) @db.Decimal(12, 2)
  totalCost    Decimal   @default(0) @db.Decimal(12, 2)
  totalLanded  Decimal   @default(0) @db.Decimal(12, 2)
  note         String?
  orderedAt    DateTime?
  receivedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items PurchaseOrderItem[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  qty             Int
  unitCost        Decimal       @db.Decimal(12, 2)
  totalCost       Decimal       @db.Decimal(12, 2)
  qtyReceived     Int           @default(0)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

// ============================================================
// B2B / COUNTERPARTIES (docs/B2B_COUNTERPARTIES.md)
// ============================================================

enum CounterpartyType {
  INDIVIDUAL
  ORGANIZATION
}

model Counterparty {
  id       String           @id @default(cuid())
  tenantId String
  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type     CounterpartyType
  name     String
  taxId    String? // required for ORGANIZATION — app-level check, not a DB constraint (Prisma cannot express "required iff type=X")
  phone    String?
  email    String?
  address  String?
  note     String?
  isActive Boolean          @default(true)

  // Optional link when the same partner both buys wholesale and supplies
  // stock. Nullable + unique: at most one Counterparty per Supplier, never
  // required, never backfilled for existing Supplier rows.
  supplierId String?   @unique
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  // Cached running balance (docs/B2B_COUNTERPARTIES.md §7). Updated
  // atomically alongside every CounterpartyLedger row in the same
  // transaction — never computed by a separate reconciliation job.
  currentDebt Decimal @default(0) @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices CounterpartyPrice[]
  ledger CounterpartyLedger[]
  orders Order[]

  @@index([tenantId])
  @@map("counterparties")
}

// Uniqueness note (docs/B2B_COUNTERPARTIES.md §5.2/§12.3): Postgres does
// not treat NULL = NULL in a unique index, so a plain
// @@unique([counterpartyId, productId, variantId]) would NOT stop two rows
// with variantId = NULL (a non-variant product) from being inserted for
// the same counterparty+product pair. Rather than keep a @@unique here
// that only half-covers the real constraint, uniqueness for this model is
// enforced entirely by two partial unique indexes added by raw SQL in the
// migration (one for variantId IS NULL, one for variantId IS NOT NULL) —
// see that migration's comment for the full reasoning. There is
// deliberately no @@unique line in this model.
model CounterpartyPrice {
  id             String          @id @default(cuid())
  counterpartyId String
  counterparty   Counterparty    @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  price          Decimal         @db.Decimal(12, 2)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("counterparty_prices")
}

enum CounterpartyLedgerType {
  ORDER_CHARGE
  PAYMENT_RECEIVED
  ADJUSTMENT
}

model CounterpartyLedger {
  id             String                 @id @default(cuid())
  tenantId       String
  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  counterpartyId String
  counterparty   Counterparty           @relation(fields: [counterpartyId], references: [id], onDelete: Cascade)
  type           CounterpartyLedgerType
  // Signed, same convention as StockLedgerEntry.delta: positive increases
  // currentDebt, negative decreases it. ORDER_CHARGE rows are always
  // positive; PAYMENT_RECEIVED rows are always negative; ADJUSTMENT can
  // be either.
  delta Decimal @db.Decimal(12, 2)

  // Only ever set for ORDER_CHARGE — a payment is a free-standing amount
  // against the counterparty's overall balance, not tied to one order
  // (docs/B2B_COUNTERPARTIES.md §7).
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  // ORDER_CHARGE only. originalDueDate is written once at creation and
  // never changes. dueDate starts equal to originalDueDate and is the one
  // field on this row that IS mutated after creation, when a due date is
  // extended (docs/B2B_COUNTERPARTIES.md §7) — a deliberate, narrow
  // exception to this ledger otherwise being append-only.
  originalDueDate DateTime?
  dueDate         DateTime?

  note      String?
  createdAt DateTime @default(now())

  @@index([tenantId, counterpartyId, createdAt])
  @@map("counterparty_ledger")
}

