# ═══════════════════════════════════════════════════════════
# SellGram — Environment Variables (Windows Dev)
# ═══════════════════════════════════════════════════════════

# ── Database (PostgreSQL on port 5433) ───────────────────
DATABASE_URL=postgresql://sellgram:sellgram_pass@localhost:5433/sellgram

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets ──────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_change_in_production_abcdef1234567890abcdef1234567890
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production_1234567890abcdef

# ── S3 / MinIO ──────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=sellgram
S3_REGION=us-east-1

# ── Bot Token Encryption ────────────────────────────────
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── URLs ─────────────────────────────────────────────────
APP_URL=http://localhost:4000
ADMIN_URL=http://localhost:5173
MINIAPP_URL=http://localhost:5174
LANDING_URL=https://sellgram.uz
SUPPORT_EMAIL=support@sellgram.uz
PRIVACY_EMAIL=privacy@sellgram.uz
BILLING_EMAIL=billing@sellgram.uz
LEGAL_ENTITY_NAME=OOO SellGram
LEGAL_ENTITY_SHORT_NAME=SellGram
LEGAL_ENTITY_ADDRESS=Tashkent, Uzbekistan
LEGAL_ENTITY_INN=XXXXXXXXX
BILLING_BANK_NAME=Kapitalbank
BILLING_BANK_ACCOUNT=2020 8000 9051 XXXX XXXX
BILLING_RECIPIENT=OOO SellGram
BILLING_INN=XXXXXXXXX
BILLING_MFO=XXXXX
BILLING_PAYMENT_NOTE=Subscription payment for SellGram
GA_MEASUREMENT_ID=
YANDEX_METRIKA_ID=

# ── API Port ─────────────────────────────────────────────
API_PORT=4000
TRUST_PROXY=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# ── Timezone ─────────────────────────────────────────────
TZ=Asia/Tashkent

# System admin API (/api/system-admin/*)
SYSTEM_JWT_SECRET=dev_system_jwt_secret_change_me_1234567890
SYSTEM_ADMIN_EMAIL=root@sellgram.uz
SYSTEM_ADMIN_PASSWORD=ChangeMe_123!

# Mini app auth hardening
MINIAPP_INITDATA_MAX_AGE_SEC=600
ALLOW_DEV_AUTH_BYPASS=false

# Production bootstrap
PRISMA_SEED=false

# Demo seed bot token (set real token before db:seed)
DEMO_BOT_TOKEN=DEMO_BOT_TOKEN_REPLACE_ME

# Nginx SSL mode for production template selection
SSL_MODE=http
SSL_COMMON_NAME=sellgram.uz

# Health monitoring
MONITOR_HEALTH_URL=http://localhost:4000/health
MONITOR_TIMEOUT_SEC=10
MONITOR_TELEGRAM_BOT_TOKEN=
MONITOR_TELEGRAM_CHAT_ID=


